{
    "compilerOptions": {
        "noImplicitAny": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "noImplicitThis": true,
        "noImplicitReturns": true,
        "strictNullChecks" : false,
        "noUnusedLocals": false,
        "noEmitOnError": true,
        "removeComments": false,
        "preserveConstEnums": true,
        "sourceMap": true,
        "strict": true
    },  
    "include": [
      "src"
    ],
    "exclude": [
        "node_modules"
    ]
}